# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/worktrack.db

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: azure | openai | ollama
LLM_PROVIDER=azure
# Default model used for extraction (must match a key in the model map)
LLM_MODEL=Claude Sonnet 4.6

# ── Azure / NLP endpoint (mirrors reference chatbot) ─────────────────────────
# NLP endpoint for GPT models
NLP_ENDPOINT=https://api.nlp.p.uptimize.merckgroup.com
NLP_API_VERSION=2024-02-01
# Bedrock endpoint for Claude models
BEDROCK_ENDPOINT=https://api.nlp.p.uptimize.merckgroup.com/model
BEDROCK_API_VERSION=2024-02-01

# ── API keys ──────────────────────────────────────────────────────────────────
# Option A: JSON blob (same pattern as reference chatbot)
# APP_SERVICE_CONFIG={"AWS_BEDROCK_KEY": "...", "APP_SERVICE_NLP_API_KEY": "..."}
#
# Option B: direct env vars
# AWS_BEDROCK_KEY=your-bedrock-key-here
# APP_SERVICE_NLP_API_KEY=your-nlp-api-key-here

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma

# ── Embeddings ────────────────────────────────────────────────────────────────
# Model used for ChromaDB embeddings (NLP endpoint)
EMBEDDING_MODEL=text-embedding-3-small
