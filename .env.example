# ── Database (Uptimize DBaaS PostgreSQL) ──────────────────────────────────────
# Everyone uses the same shared PostgreSQL database — local and production.
# This ensures you always see real data and avoids SQLite/PostgreSQL mismatches.
#
DATABASE_URL=postgresql://db_MbCaBw-X288712@ec1-dbaas-rds-aurora.cluster-cjk5epdyjney.eu-central-1.rds.amazonaws.com:5432/db_MbCaBw
DBAAS_HOST=ec1-dbaas-rds-aurora.cluster-cjk5epdyjney.eu-central-1.rds.amazonaws.com
DBAAS_PORT=5432
DBAAS_USER=db_MbCaBw-X288712
DBAAS_IAM_ROLE=arn:aws:iam::538741841777:role/db_MbCaBw-1cf05322
DBAAS_REGION=eu-central-1
#
# ── Local dev DB token (DO NOT set on App Service) ───────────────────────────
# On App Service, the ECS task role generates tokens automatically.
# Locally, get a token from the DBaaS console:
#   1. Go to Uptimize App Service → Databases → your database → "Get Credentials"
#   2. Copy the "password" value and paste it below (valid ~15 min)
#   3. When it expires, repeat steps 1-2
#
# DBAAS_AUTH_TOKEN=<paste-password-from-dbaas-console>

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: azure | openai | ollama
LLM_PROVIDER=azure
# Default model used for extraction (must match a key in the model map)
LLM_MODEL=Claude Sonnet 4.6

# ── Azure / NLP endpoint (mirrors reference chatbot) ─────────────────────────
# NLP endpoint for GPT models
NLP_ENDPOINT=https://api.nlp.p.uptimize.merckgroup.com
NLP_API_VERSION=2024-02-01
# Bedrock endpoint for Claude models
BEDROCK_ENDPOINT=https://api.nlp.p.uptimize.merckgroup.com/model
BEDROCK_API_VERSION=2024-02-01

# ── API keys ──────────────────────────────────────────────────────────────────
# On App Service, enter runtime config as APP_SERVICE_CONFIG JSON.
# All keys in the JSON are injected as individual env vars at startup.
# Required APP_SERVICE_CONFIG for App Service:
# {
#   "SECRET_KEY": "a-long-random-string",
#   "AWS_BEDROCK_KEY": "your-bedrock-key",
#   "APP_SERVICE_NLP_API_KEY": "your-nlp-api-key"
# }
#
# For local dev, set keys directly:
# AWS_BEDROCK_KEY=your-bedrock-key-here
# APP_SERVICE_NLP_API_KEY=your-nlp-api-key-here

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma

# ── Embeddings ────────────────────────────────────────────────────────────────
# Model used for ChromaDB embeddings (NLP endpoint)
EMBEDDING_MODEL=text-embedding-3-small
